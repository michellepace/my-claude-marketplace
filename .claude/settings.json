{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(claude mcp get *)",
      "Bash(claude mcp list)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh run list *)",
      "Bash(jq *)",
      "Bash(gh run view *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(rsvg-convert *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.envrc)"
    ],
    "ask": []
  }
}
